# ===== MONKEYGOD environment =====
# Copy this file to ".env" and fill in the real values, then restart the server.

# Port the site runs on locally
PORT=4000

# Public URL of the site (used to build redirect-back URLs).
# Locally this is fine as-is. In production set it to https://monkeygod.cloud
PUBLIC_BASE_URL=http://localhost:4000

# ---------- DOMAINS ----------
# One app serves both. Main site (.fun) sends buyers to the payment site (.xyz).
MAIN_SITE_URL=https://monkeygod.fun
PAYMENT_SITE_URL=https://monkeygod.cloud
PAYMENT_HOST=monkeygod.cloud

# ---------- SQUARE (embedded Web Payments SDK) ----------
# Where to talk to Square: "sandbox" while testing, "production" when live.
SQUARE_ENV=production

# All three come from the SAME Square app (use the Production tab to go live):
#   Application ID  -> Developer Dashboard -> your app -> Credentials  (PUBLIC, used in browser)
#   Access token    -> Developer Dashboard -> your app -> Credentials  (SECRET, server only)
#   Location ID     -> Developer Dashboard -> your app -> Locations
SQUARE_ACCESS_TOKEN=
SQUARE_APP_ID=
SQUARE_LOCATION_ID=

# ---------- CONFIG SOURCE (Cloudflare R2 bucket) ----------
# PRODUCTION: this app reads Square keys + crypto + links from data/config.json
# inside the R2 bucket below (so the keys can be changed without redeploying).
# If these R2_* values are blank, it falls back to the SQUARE_*/CRYPTO_*/TELEGRAM_*
# vars in this file (fine for local dev).
# Make an R2 API token: Cloudflare dashboard -> R2 -> "Manage R2 API Tokens"
# (Object Read & Write on the "monkeygod" bucket). It gives an Access Key ID +
# Secret Access Key. Find R2_ACCOUNT_ID on the R2 overview page.
R2_ACCOUNT_ID=
R2_BUCKET=monkeygod
R2_CONFIG_KEY=data/config.json
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ---------- CRYPTO ----------
# Wallet addresses shown on the crypto checkout. Leave blank to hide a coin.
CRYPTO_BTC=
CRYPTO_ETH=
CRYPTO_USDT_TRC20=
CRYPTO_LTC=
CRYPTO_SOL=

# ---------- LINKS ----------
TELEGRAM_ADMIN=https://t.me/youradmin
TELEGRAM_CHANNEL=https://t.me/yourchannel
TELEGRAM_CHATROOM=https://t.me/yourchatroom

# ---------- PER-TIER PRIVATE CHANNELS ----------
# Shown to the buyer immediately after a successful payment (no redirect).
# In production these come from tierLinks in the R2 config.json instead.
TIER_LINK_BASIC=
TIER_LINK_PREMIUM=
TIER_LINK_EXCLUSIVE=
